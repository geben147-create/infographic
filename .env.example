# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default

# Database
DATABASE_URL=sqlite:///data/pipeline.db

# Google Sheets (required for sync)
GOOGLE_SHEETS_CREDENTIALS=path/to/service-account.json
GOOGLE_SHEETS_ID=your-spreadsheet-id-here

# Phase 2: Local AI services
OLLAMA_URL=http://localhost:11434
COMFYUI_URL=http://localhost:8188

# Phase 2: Cloud AI APIs (leave empty to disable)
FAL_KEY=
# FAL_KEY=fal_xxxxxxxxxxxxxxxxxxxxxxxxxx  # get from https://fal.ai/dashboard

# Phase 2: YouTube upload (path to OAuth2 client_secrets.json from GCP Console)
YOUTUBE_CLIENT_SECRETS=

# Phase 2: Cost tracking
COST_LOG_PATH=data/cost_log.json

# Phase 2: Config directories
CHANNEL_CONFIGS_DIR=src/channel_configs
PROMPT_TEMPLATES_DIR=src/prompt_templates

# Phase 2: Assets
FONT_PATH=assets/fonts/NotoSansKR-Bold.ttf
