# =============================================================================
# YouTube Video Automation Pipeline — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control (it is in .gitignore).

# -----------------------------------------------------------------------------
# Phase 1: Infrastructure
# -----------------------------------------------------------------------------

# Temporal workflow orchestration server address
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default

# SQLite database (file-based, no ops required)
DATABASE_URL=sqlite:///data/pipeline.db

# Google Sheets sync (optional — required only for Sheets input/output)
# Set GOOGLE_SHEETS_CREDENTIALS to the path of your GCP service account JSON.
# Set GOOGLE_SHEETS_ID to the spreadsheet ID (from the Sheets URL).
GOOGLE_SHEETS_CREDENTIALS=path/to/service-account.json
GOOGLE_SHEETS_ID=your-spreadsheet-id-here

# -----------------------------------------------------------------------------
# Phase 2: Local AI services (run on RTX 4070 8GB)
# -----------------------------------------------------------------------------

# Ollama LLM server (serves Qwen3-14B for script generation)
OLLAMA_URL=http://localhost:11434

# ComfyUI image generation server (serves SDXL/FLUX)
COMFYUI_URL=http://localhost:8188

# -----------------------------------------------------------------------------
# Phase 2: Cloud AI APIs
# -----------------------------------------------------------------------------

# fal.ai API key — required for AI video generation (WAN 2.2/2.5)
# Leave empty to disable AI video generation (Ken Burns FFmpeg fallback is used)
# Cost: ~$0.05-0.10/sec of generated video
# Get your key at: https://fal.ai/dashboard/keys
FAL_KEY=
# FAL_KEY=fal_xxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Phase 2: YouTube Data API v3
# -----------------------------------------------------------------------------

# Path to the OAuth2 client_secrets.json downloaded from GCP Console.
# Required to run the OAuth2 authorization flow for YouTube upload.
# Each channel needs its own authorized token (stored in data/yt_token_*.json).
YOUTUBE_CLIENT_SECRETS=
# YOUTUBE_CLIENT_SECRETS=data/client_secrets.json

# -----------------------------------------------------------------------------
# Phase 2: Cost tracking
# -----------------------------------------------------------------------------

# Path where per-activity cost entries are appended (JSON array)
# This file is read by the API's /cost/{workflow_id} endpoint.
COST_LOG_PATH=data/cost_log.json

# -----------------------------------------------------------------------------
# Phase 2: Content configuration
# -----------------------------------------------------------------------------

# Directory containing per-channel YAML config files
# Each file: {CHANNEL_CONFIGS_DIR}/{channel_id}.yaml
CHANNEL_CONFIGS_DIR=src/channel_configs

# Directory containing Jinja2 prompt template files (.j2)
# Referenced by ChannelConfig.prompt_template field
PROMPT_TEMPLATES_DIR=src/prompt_templates

# -----------------------------------------------------------------------------
# Phase 2: Assets
# -----------------------------------------------------------------------------

# Path to the NotoSansKR-Bold TrueType font used for thumbnail text overlays.
# Falls back to Pillow's built-in default font if this file is not found.
# Download: https://fonts.google.com/noto/specimen/Noto+Sans+KR
FONT_PATH=assets/fonts/NotoSansKR-Bold.ttf
